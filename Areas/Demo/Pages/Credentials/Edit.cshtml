@page
@model EditModel


@{
    ViewData ["Title"] = "Credential - Edit";
}

<h4 class="align-text-top text-muted m-2">@ViewData["Title"]</h4>
<hr />

<div class="container-fluid p-1 m-2" style="background-color:#f4f4f4; box-shadow: 5px 5px 10px 5px #e1e1e1;">
    <p>
        <a asp-area="Demo" asp-page="/Home/Index"><i class="bi bi-house-up" title="Demo Home"></i></a>&nbsp;&nbsp;&nbsp;
        <a asp-area="Demo" asp-page="/credential/Index"><i class="bi bi-arrow-return-left" title="credential Setup"></i></a>&nbsp;&nbsp;&nbsp;
        <a asp-area="Demo" asp-page="/credential/Create"><i class="bi bi-plus-square" title="Create Credential"></i></a>

        <img src="~/img/setup.png" class="img-fluid" style="float:right;height:auto; width:70px;" title="Setup" />
    </p>
</div>
<hr/>
<div class="container pagemiddle p-3 m-1">
    <form method="post">
        <input type="hidden" asp-for=credential.Id class="form-control" />

        <div class="row p-1">
            <div class="col-auto col-md-4">
                <label class="form-check-label"></label>
                <div class="input-group form-check">
                    <input asp-for=credential.IsChecked class="form-check-input" />
                </div>
            </div>
        </div>
        <div class="row p-1">
            <div class="col-auto col-md-4">
                <label asp-for=credential.SiteUrl class="control-label"></label>
                <div class="input-group">
                    <input asp-for=credential.SiteUrl class="form-control" />
                    <span asp-validation-for=credential.SiteUrl class="text-danger"></span>
                </div>
            </div>
            <div class="col-auto col-md-4">
                <label asp-for=credential.UserName class="control-label"></label>
                <div class="input-group">
                    <input asp-for=credential.UserName class="form-control" />
                    <span asp-validation-for=credential.UserName class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="row p-1">
            <div class="col-auto col-md-4">
                <label asp-for=credential.Password class="control-label"></label>
                <div class="input-group">
                    <input asp-for=credential.Password class="form-control" />
                    <span asp-validation-for=credential.Password class="text-danger"></span>
                </div>
            </div>
            <div class="col-auto col-md-4">
                <label asp-for=credential.Tenant class="control-label"></label>
                <div class="input-group">
                    <input asp-for=credential.Tenant class="form-control" />
                    <span asp-validation-for=credential.Tenant class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="row p-1">
            <div class="col-auto col-md-4">
                <label asp-for=credential.Branch class="control-label"></label>
                <div class="input-group">
                    <input asp-for=credential.Branch class="form-control" />
                    <span asp-validation-for=credential.Branch class="text-danger"></span>
                </div>
            </div>
            <div class="col-auto col-md-4">
                <label asp-for=credential.Locale class="control-label"></label>
                <div class="input-group">
                    <input asp-for=credential.Locale class="form-control" />
                    <span asp-validation-for=credential.Locale class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group">
            <br/>
            <input type="submit" value="Save" class="btn btn-primary" />
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
